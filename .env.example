# MiniMax API Key - 用于 AI 摘要生成 (https://platform.minimaxi.com)
MINIMAX_API_KEY=eyxxxxx

# MiniMax 模型 (可选，默认 MiniMax-Text-01)
# MINIMAX_MODEL=MiniMax-Text-01

# Resend API Key - 用于邮件发送 (https://resend.com)
RESEND_API_KEY=re_xxx

# 发件人邮箱 (需在 Resend 中验证域名，或使用 onboarding@resend.dev 测试)
EMAIL_FROM=onboarding@resend.dev

# 收件人邮箱列表 (逗号分隔)
EMAIL_TO=user1@example.com,user2@example.com

# Vercel Cron Secret (防止未授权调用)
CRON_SECRET=your-secret-here
